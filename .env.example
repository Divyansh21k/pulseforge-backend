# ============================================================
#  PulseForge Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  Run:  cp .env.example .env
# ============================================================

# ----- Database -----
# Default is a local SQLite file (no setup needed for development)
DATABASE_URL=sqlite:///./pulseforge.db

# ----- Google Gemini -----
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----- Resend (Email) -----
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Sender email address.
# FREE PLAN:  Use "onboarding@resend.dev" — but you can ONLY send to the email
#             address you signed up with on Resend (your own verified email).
# PRODUCTION: Verify a domain at https://resend.com/domains and use
#             "noreply@yourdomain.com" to send to anyone.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ----- Vapi.ai (Voice Assistant) -----
# Get these from your Vapi dashboard: https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Only needed for outbound calls (leave blank if not using)
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
