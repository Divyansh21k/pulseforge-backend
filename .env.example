# ============================================================
#  PulseForge Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  Run:  cp .env.example .env
# ============================================================

# ----- Database -----
DATABASE_URL=sqlite:///./pulseforge.db

# ----- Google Gemini -----
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----- Gmail SMTP (email) -----
# The Gmail address to send emails FROM (e.g. pulseforge.team@gmail.com)
GMAIL_SENDER_EMAIL=your_gmail_address@gmail.com

# A Gmail APP PASSWORD — NOT your normal Gmail password!
# How to get one:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (turn it ON if not already)
#   3. Search "App Passwords" → select app "Mail" → Generate
#   4. Copy the 16-character password shown and paste below (no spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ----- Vapi.ai (Voice Assistant) -----
# Get these from your Vapi dashboard: https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Only needed for outbound calls (leave blank if not using)
VAPI_PHONE_NUMBER_ID=
